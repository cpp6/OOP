import java.util.*;

class Book {
	int id;
	String title;
	String auther;
	Boolean isIssued;

	static int totalbooks = 0;

	Book(int id, String title, String auther) {
		this.id = id;
		this.title = title;
		this.auther = auther;
		this.isIssued = false;
		totalbooks++;
	}

	void DisplayBook() {
		System.out.println("ID: " + id + " " + "Title: " + title + " " + "Auther: " + auther + " " + "Issued: "
				+ "Issued: " + (isIssued ? "Yes" : "No"));
	}

	void IssueBook() {
		if (!isIssued) {
			isIssued = true;
			System.out.println("Book issued successfully!");
		} else {
			System.out.println("Book was already issued!");
		}
	}

	void Returnbook() {
		if (isIssued) {
			isIssued = false;
			System.out.println("Book returned successdully!");
		} else {
			System.out.println("Book was not issued!");
		}
	}

	static void showTotalBooks() {
		System.out.println("Total books: " + totalbooks);
	}
}

public class LibraryManagementSystem {
	public static void main(String args[]) {
		Scanner sc = new Scanner(System.in);
		ArrayList<Book> library = new ArrayList<>();

		while (true) {
			System.out.println("===Library Managemetn System===");
			System.out.println("1. Add Book");
			System.out.println("2. View Book");
			System.out.println("3. Issue Book");
			System.out.println("4. Return Book");
			System.out.println("5. Total book");
			System.out.println("6. Exit");

			System.out.print("Enter choice: ");
			int choice = sc.nextInt();

			switch (choice) {

				case 1:
					System.out.print("Enter book id: ");
					int id = sc.nextInt();
					sc.nextLine();

					System.out.print("Enter Title of Book: ");
					String title = sc.nextLine();

					System.out.print("Enter Auther of Book: ");
					String auther = sc.nextLine();

					library.add(new Book(id, title, auther));
					System.out.println("Book added successfully!");
					break;
				case 2:
					if (library.isEmpty()) {
						System.out.println("Books are not available!");
					} else {
						for (Book b : library) {
							b.DisplayBook();
						}
					}
					break;

				case 3:
					System.out.print("Enter Book ID to Issue: ");
					int issueId = sc.nextInt();
					boolean foundIssue = false;

					for (Book b : library) {
						if (b.id == issueId) {
							b.IssueBook();
							foundIssue = true;
							break;
						}
					}
					if (!foundIssue) {
						System.out.println("Book not found!");
					}
					break;

				case 4:
					System.out.print("Enter Book ID to return: ");
					int returnId = sc.nextInt();
					boolean foundReturn = false;

					for (Book b : library) {
						if (b.id == returnId) {
							b.Returnbook();
							foundReturn = true;
							break;
						}
					}
					if (!foundReturn) {
						System.out.println("Book not found!");
					}
					break;

				case 5:
					Book.showTotalBooks();
					break;

				case 6:
					System.out.println("Exiting...");
					sc.close();
					return;

				default:
					System.out.println("Invalid choice!");
			}

		}

	}
}
